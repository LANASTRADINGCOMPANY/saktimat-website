---
import '../styles/global.css'
import logo from '../assets/logo.png'

interface Props {
  title?: string
  description?: string
}

const {
  title = 'Saktimat',
  description = 'An AI-powered behavioural operating system for people who think differently.',
} = Astro.props
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <slot name="head" />
  </head>
  <body class="bg-[#FAF7F2] text-[#3D4259]">

    <header class="w-full border-b border-[#1A1A2E]/8 relative">
      <div class="max-w-5xl mx-auto px-6 py-4 flex items-center justify-between">

        <a href="/" class="flex items-center gap-2">
          <img src={logo.src} alt="Saktimat" class="h-16 w-16" />
          <span class="text-xl font-semibold text-[#1A1A2E] tracking-tight">Saktimat</span>
        </a>

        <nav class="hidden md:flex items-center gap-6 text-sm text-[#3D4259]">
          <a href="/" class="hover:text-[#1A1A2E] transition-colors">Home</a>
          <a href="/how-it-works" class="hover:text-[#1A1A2E] transition-colors">How it works</a>
          <a href="/install" class="hover:text-[#1A1A2E] transition-colors">Install</a>
          <a href="/resources" class="hover:text-[#1A1A2E] transition-colors">Resources</a>
        </nav>

        <div class="flex items-center gap-3">
          <a
            href="https://app.saktimat.com"
            target="_blank"
            rel="noopener noreferrer"
            class="bg-[#4A90D9] text-white text-sm font-medium px-5 py-2 rounded-full hover:bg-[#3a7bc8] transition-colors"
          >
            Open App
          </a>

          <button
            id="mobile-menu-button"
            class="md:hidden p-2 -mr-2"
            aria-label="Open menu"
            aria-expanded="false"
          >
            <svg id="menu-icon-open" class="w-6 h-6 text-[#1A1A2E]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
            </svg>
            <svg id="menu-icon-close" class="w-6 h-6 text-[#1A1A2E] hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
            </svg>
          </button>
        </div>

      </div>

      <nav
        id="mobile-menu"
        class="hidden md:hidden flex-col gap-1 px-6 pb-4 text-sm text-[#3D4259] border-t border-[#1A1A2E]/8 pt-4"
      >
        <a href="/" class="py-2 hover:text-[#1A1A2E] transition-colors">Home</a>
        <a href="/how-it-works" class="py-2 hover:text-[#1A1A2E] transition-colors">How it works</a>
        <a href="/install" class="py-2 hover:text-[#1A1A2E] transition-colors">Install</a>
        <a href="/resources" class="py-2 hover:text-[#1A1A2E] transition-colors">Resources</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

    <footer class="w-full border-t border-[#1A1A2E]/8 mt-24">
      <div class="max-w-5xl mx-auto px-6 py-8 space-y-3">
        <p class="text-sm text-[#3D4259]/60 text-center">
          Currently in closed beta. Email <a href="mailto:admin@saktimat.com" class="text-[#4A90D9] hover:underline">admin@saktimat.com</a> or call <a href="tel:0435058303" class="text-[#4A90D9] hover:underline">0435058303</a> to request access.
        </p>
        <div class="flex items-center justify-between text-sm text-[#3D4259]/60">
          <a href="/privacy" class="hover:text-[#3D4259] transition-colors">Privacy</a>
          <span>© {new Date().getFullYear()} Saktimat</span>
        </div>
      </div>
    </footer>

    <script>
      const menuButton = document.getElementById('mobile-menu-button')
      const mobileMenu = document.getElementById('mobile-menu')
      const iconOpen = document.getElementById('menu-icon-open')
      const iconClose = document.getElementById('menu-icon-close')

      menuButton?.addEventListener('click', () => {
        const isHidden = mobileMenu?.classList.contains('hidden')
        mobileMenu?.classList.toggle('hidden')
        mobileMenu?.classList.toggle('flex')
        iconOpen?.classList.toggle('hidden')
        iconClose?.classList.toggle('hidden')
        menuButton?.setAttribute('aria-expanded', isHidden ? 'true' : 'false')
      })
    </script>
  </body>
</html>
