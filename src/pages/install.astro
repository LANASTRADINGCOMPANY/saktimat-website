---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Install — Saktimat"
  description="Install Saktimat on your home screen in under a minute. No app store needed."
>

  <!-- Header -->
  <section class="max-w-3xl mx-auto px-6 pt-24 pb-16 text-center">
    <h1 class="text-4xl sm:text-5xl font-semibold text-[#1A1A2E] leading-tight tracking-tight mb-5">
      Install Saktimat on your phone
    </h1>
    <p class="text-lg text-[#3D4259]/80 leading-relaxed">
      Saktimat works best as an app on your home screen. It takes less than a minute, and there's nothing to download from an app store.
    </p>
  </section>

  <!-- iPhone -->
  <section class="max-w-3xl mx-auto px-6 py-16">
    <div class="bg-white rounded-2xl shadow-sm p-10">
      <h2 class="text-2xl font-semibold text-[#1A1A2E] mb-6">iPhone (Safari)</h2>
      <ol class="list-decimal list-inside space-y-2 text-[#3D4259]/80 leading-relaxed">
        <li>Open this site in Safari (not Chrome). Go to <span class="text-[#4A90D9]">app.saktimat.com</span></li>
        <li>Tap the Share icon at the bottom of the screen</li>
        <li>Scroll down and tap <strong class="text-[#1A1A2E] font-medium">Add to Home Screen</strong></li>
        <li>Tap <strong class="text-[#1A1A2E] font-medium">Add</strong> in the top right</li>
        <li>Saktimat now appears on your home screen like any other app</li>
      </ol>
    </div>
  </section>

  <!-- Android -->
  <section class="max-w-3xl mx-auto px-6 py-16">
    <div class="bg-white rounded-2xl shadow-sm p-10">
      <h2 class="text-2xl font-semibold text-[#1A1A2E] mb-6">Android (Chrome)</h2>
      <ol class="list-decimal list-inside space-y-2 text-[#3D4259]/80 leading-relaxed">
        <li>Open this site in Chrome. Go to <span class="text-[#4A90D9]">app.saktimat.com</span></li>
        <li>Tap the three dots menu in the top right</li>
        <li>Tap <strong class="text-[#1A1A2E] font-medium">Add to Home screen</strong> or <strong class="text-[#1A1A2E] font-medium">Install app</strong></li>
        <li>Confirm by tapping <strong class="text-[#1A1A2E] font-medium">Add</strong> or <strong class="text-[#1A1A2E] font-medium">Install</strong></li>
        <li>Saktimat now appears on your home screen like any other app</li>
      </ol>
    </div>
  </section>

  <!-- Why install -->
  <section class="max-w-3xl mx-auto px-6 py-16">
    <div class="bg-white rounded-2xl shadow-sm p-10">
      <h2 class="text-2xl font-semibold text-[#1A1A2E] mb-4">Why install instead of just bookmarking?</h2>
      <p class="text-[#3D4259]/80 leading-relaxed">
        Installing Saktimat means it opens full screen, without browser bars getting in the way. It also means you can turn on daily reminders, something that only works once it's installed.
      </p>
    </div>
  </section>

  <!-- Closing CTA -->
  <section class="py-24">
    <div class="max-w-3xl mx-auto px-6 text-center bg-[#4A90D9]/8 rounded-3xl py-16">
      <h2 class="text-3xl sm:text-4xl font-semibold text-[#1A1A2E] leading-snug tracking-tight mb-8">
        Ready to install?
      </h2>
      <a
        href="https://app.saktimat.com"
        target="_blank"
        rel="noopener noreferrer"
        class="bg-[#4A90D9] text-white font-medium px-7 py-3 rounded-full hover:bg-[#3a7bc8] transition-colors inline-block"
      >
        Go to app.saktimat.com →
      </a>
    </div>
  </section>

</BaseLayout>
